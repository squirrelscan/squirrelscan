{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun", "node"],
    "paths": {
      "@squirrelscan/core-contracts": ["../core-contracts/src/index.ts"],
      "@squirrelscan/core-contracts/*": ["../core-contracts/src/*"],
      "@squirrelscan/crawler": ["../crawler/src/index.ts"],
      "@squirrelscan/crawler/*": ["../crawler/src/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
