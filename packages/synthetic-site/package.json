{
  "name": "@squirrelscan/synthetic-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "synthetic-site": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint -c oxlint.config.mjs src/ tests/",
