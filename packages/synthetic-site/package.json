    "effect": "^3.21.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "oxfmt": "^0.60.0",
    "oxlint": "1.75.0",
    "typescript": "^7.0.2",
    "ultracite": "7.9.4"
  },
  "license": "MIT"
