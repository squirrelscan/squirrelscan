{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["bun", "node"],
    "paths": {
      "@squirrelscan/api-client": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
