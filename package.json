{
  "name": "squirrelscan-monorepo",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "cd apps/cli && bun run dev",
    "build": "cd apps/cli && bun run build",
    "format": "bun run --filter '*' --if-present format",
    "format:check": "bun run --filter '*' --if-present format:check",
    "lint": "bun run --filter '*' --if-present lint",
    "typecheck": "bun run --sequential --filter '*' --if-present typecheck",
    "test": "cd apps/cli && bun test",
    "test:engine": "cd packages/audit-engine && bun run test:golden",
    "test:release": "bash scripts/test-changelog-extraction.sh && bun test scripts/release-version.test.ts",
    "check:psl-freshness": "bun run scripts/check-tldts-freshness.ts",
    "release": "bun run scripts/release.ts"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "@typescript/native-preview": "^7.0.0-dev.20260609.1",
    "semver": "^7.8.3"
  }
}
