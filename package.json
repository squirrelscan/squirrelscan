{
  "name": "squirrelscan-monorepo",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "docs", "packages/*"],
  "scripts": {
    "dev": "cd apps/cli && bun run dev",
    "build": "cd apps/cli && bun run build",
    "format": "bun run --filter '*' --if-present format",
    "format:check": "bun run --filter '*' --if-present format:check",
    "lint": "bun run --filter '*' --if-present lint",
    "typecheck": "bun run --sequential --filter '*' --if-present typecheck",
    "test": "cd apps/cli && bun test",
    "test:engine": "cd packages/audit-engine && bun run test:golden",
    "test:release": "bash scripts/test-changelog-extraction.sh && bun test scripts/release-version.test.ts",
    "docs:check": "cd docs && bun run check",
    "docs:build": "cd docs && bun run build",
    "audit:dependencies": "bun audit --ignore=GHSA-9wv6-86v2-598j",
    "notices:generate": "bun run scripts/generate-third-party-notices.ts",
    "notices:check": "bun run notices:generate && git diff --exit-code -- THIRD_PARTY_NOTICES.md npm/THIRD_PARTY_NOTICES.md",
    "check:psl-freshness": "bun run scripts/check-tldts-freshness.ts",
    "release": "bun run scripts/release.ts"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "@typescript/native-preview": "^7.0.0-dev.20260609.1",
    "cookie": "2.0.1",
    "semver": "^7.8.3"
  },
  "overrides": {
    "@astrojs/cloudflare": "14.1.4",
    "@astrojs/mdx": "7.0.3",
    "@astrojs/node": "11.0.2",
    "@astrojs/vercel": "11.0.3",
    "@hono/node-server": "2.0.11",
    "astro": "7.1.3",
    "esbuild": "0.28.1",
    "fast-xml-parser": "5.10.1",
    "sharp": "0.35.3"
  }
}
