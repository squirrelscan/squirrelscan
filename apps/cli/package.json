{
  "name": "@squirrelscan/cli",
  "version": "0.0.79",
  "description": "Free CLI for SEO, performance & security audits. Built for Claude Code, Cursor, and AI workflows.",
  "bin": {
    "squirrelscan": "./build/squirrelscan"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile build/squirrelscan",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint -c oxlint.config.mjs src/ tests/",
    "format": "oxfmt src/ tests/ --write",
    "format:check": "oxfmt src/ tests/ --check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@squirrelscan/api-client": "workspace:*",
    "@squirrelscan/audit-engine": "workspace:*",
    "@squirrelscan/cloud-client": "workspace:*",
    "@squirrelscan/config": "workspace:*",
    "@squirrelscan/core-contracts": "workspace:*",
    "@squirrelscan/crawler": "workspace:*",
    "@squirrelscan/fetchers": "workspace:*",
    "@squirrelscan/parser": "workspace:*",
    "@squirrelscan/report": "workspace:*",
    "@squirrelscan/rules": "workspace:*",
    "@squirrelscan/utils": "workspace:*",
    "citty": "^0.1.6",
    "effect": "^3.21.3",
    "fast-xml-parser": "^5.10.1",
    "gradient-string": "^3.0.0",
    "linkedom": "^0.18.12",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "robots-parser": "^3.0.1",
    "smol-toml": "^1.6.1",
    "ts-edge": "^1.0.4",
    "user-agents": "^1.1.675",
    "uuidv7": "^1.2.1",
    "xml2js": "^0.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/xml2js": "^0.4.14",
    "bun-types": "^1.3.14",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "oxfmt": "^0.21.0",
    "oxlint": "1.73.0",
    "oxlint-plugin-react-doctor": "^0.7.1",
    "semver": "^7.8.3",
    "typescript": "^5.9.3",
    "ultracite": "7.9.2"
  },
  "private": true,
  "license": "MIT"
}
